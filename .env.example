# ─── EasyPost ────────────────────────────────────────────────────────────────
# Required: your EasyPost API key.
# Test key starts with EZTK, production key starts with EZAK.
EASYPOST_API_KEY=

# EasyPost environment: sandbox or production (default: sandbox)
EASYPOST_MODE=sandbox

# ─── Application ─────────────────────────────────────────────────────────────
# Application environment: development, test, or production (default: development)
NODE_ENV=development

# Log level: trace, debug, info, warn, error, fatal, silent (default: info)
LOG_LEVEL=info

# ─── EasyPost client tuning ───────────────────────────────────────────────────
# EasyPost API request timeout in milliseconds (default: 30000)
EASYPOST_TIMEOUT_MS=30000

# Number of retry attempts for retryable EasyPost errors (0–5, default: 2)
EASYPOST_RETRY_ATTEMPTS=2

# MCP tool call rate limit per minute per tool (default: 60)
MCP_RATE_LIMIT_PER_MINUTE=60

# ─── HTTP transport ───────────────────────────────────────────────────────────
# Bind host and port for --mode=http (default: 0.0.0.0:8080)
MCP_HTTP_PORT=8080
MCP_HTTP_HOST=0.0.0.0

# Cloud Run (and other container runtimes) set PORT automatically.
# When PORT is present it overrides MCP_HTTP_PORT — leave blank locally.
# PORT=8080

# ─── OAuth 2.0 (HTTP transport only) ─────────────────────────────────────────
# The public base URL of this server (e.g. https://your-cloud-run-url.run.app)
# Required for OAuth discovery and redirect URIs.
OAUTH_ISSUER_URL=

# OAuth client ID presented by MCP connectors (default: easypost-mcp)
OAUTH_CLIENT_ID=easypost-mcp

# OAuth client secret used to validate token exchange.
# Store this in GCP Secret Manager in production; never commit it.
OAUTH_CLIENT_SECRET=

# Authorization code lifetime in seconds (default: 300 = 5 minutes)
OAUTH_CODE_EXPIRY_SECONDS=300

# Access token lifetime in seconds (default: 3600 = 1 hour)
OAUTH_TOKEN_EXPIRY_SECONDS=3600

# ─── GCP (populated automatically by Cloud Run — do not set manually) ─────────
# These are injected by the Cloud Run runtime or Secret Manager mounts.
# GOOGLE_CLOUD_PROJECT=
# K_SERVICE=
# K_REVISION=
