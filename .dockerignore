# Version control
.git/
.gitignore

# Python cache
__pycache__/
*.py[cod]
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# Local environment — never bake secrets into the image
.env
.env.local
.env.*.local

# Development / test artifacts
tests/
*.egg-info/
dist/
build/
htmlcov/
.coverage

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Docs (not needed at runtime)
README.md
docs/

# Docker files themselves (not needed inside the image)
Dockerfile
.dockerignore
deploy.sh
cloudbuild.yaml
